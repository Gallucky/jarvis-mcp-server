# --- Obsidian Local REST API plugin ---
# In Obsidian: Settings → Local REST API → Enable HTTP server
# Copy the port and API key shown there.
OBSIDIAN_API_BASE_URL=http://127.0.0.1:27123
OBSIDIAN_API_KEY=paste_your_obsidian_local_rest_api_key_here

# --- Public URL (where Tailscale / your reverse proxy exposes this server) ---
# No trailing slash.
PUBLIC_BASE_URL=https://your-machine.your-tailnet.ts.net

# --- OAuth client (pre-registered for Claude) ---
# Generate these once and paste them into Claude's connector UI.
# node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"  → CLIENT_ID
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"  → CLIENT_SECRET
OAUTH_CLIENT_ID=generate_a_random_hex_string
OAUTH_CLIENT_SECRET=generate_a_longer_random_hex_string

# --- Server ---
PORT=3701
TRANSPORT=http
